# Test Environment Configuration
# This file is loaded by tests/e2e/playwright.setup.ts before tests run

# Test API key (distinct from production key)
TEST_API_KEY=test-api-key-123

# Test database path (isolated from dev/production)
TEST_DB_PATH=./data/test-db.lance

# Test server port (can differ from dev server)
TEST_PORT=8000

# Embeddings cache directory for tests
TEST_EMBEDDINGS_CACHE=./data/test-embeddings

# OpenAI API key (use test key or actual key if needed for embeddings)
# If actual testing requires real embeddings, use a real key
# If using mock embeddings in tests, this can be empty
OPENAI_API_KEY=

# Server host for tests
TEST_HOST=127.0.0.1

# Log level for tests (more verbose than production)
LOG_LEVEL=DEBUG
